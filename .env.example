# =============================================================
# SustentaCafe — Exemplo de Configuração
# Copie para .env e preencha com valores reais.
# O Docker Compose gera automaticamente esses segredos na primeira subida.
# Se você rodar o backend fora do Docker, gere manualmente com:
# node -e "require('crypto').randomBytes(16).toString('hex')"
# =============================================================

# --- JWT (gere 32 chars hex para cada) ---
JWT_SECRET=<gere_com_openssl_rand_hex_16>
JWT_REFRESH_SECRET=<gere_com_openssl_rand_hex_16>

# --- Banco de Dados ---
DB_HOST=db
DB_PORT=5432
DB_NAME=sustentabilidade_rural
DB_USER=postgres
DB_PASSWORD=<gere_com_openssl_rand_hex_16>

# --- Aplicação ---
APP_PORT=4300
NODE_ENV=production
FRONTEND_URL=https://cafe.h3info.com:4300
FRONTEND_URL=http://cafe.h3info.com:4300